OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_TEXT_PROVIDER=openai
AI_IMAGE_PROVIDER=none
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Backend
PORT=4000
WEB_ORIGIN=http://localhost:5173

# Comma-separated production origins for deployed frontend(s).
# Example: https://magi-web.vercel.app,https://magi-web-git-main-your-team.vercel.app
CORS_ORIGINS=https://*.vercel.app
# Optional: allow all https://*.vercel.app preview origins
ALLOW_VERCEL_PREVIEW_ORIGINS=true
# Optional: override the conversation store location
# CONVERSATION_STORE_PATH=

# Frontend
VITE_API_BASE_URL=http://localhost:4000
